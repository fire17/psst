#!/usr/bin/env zsh
# psst — gentle hints for your shell. CLI manager.
# https://github.com/fire17/psst
emulate -R zsh
setopt extended_glob typeset_silent

typeset -g PSST_VERSION="0.4.0"
typeset -g SCRIPT=${0:A}
typeset -g PSST_ROOT=${SCRIPT:h:h}
source "$PSST_ROOT/lib/core.zsh"

# ---------- ui helpers ----------
if [[ -t 1 && -z $NO_COLOR ]]; then
  typeset -g C_DIM=$'\e[2m' C_BOLD=$'\e[1m' C_PINK=$'\e[38;5;213m' C_GREEN=$'\e[32m'
  typeset -g C_RED=$'\e[31m' C_YEL=$'\e[33m' C_CYAN=$'\e[36m' C_OFF=$'\e[0m'
else
  typeset -g C_DIM='' C_BOLD='' C_PINK='' C_GREEN='' C_RED='' C_YEL='' C_CYAN='' C_OFF=''
fi

die()  { print -r -- "${C_RED}psst:${C_OFF} $*" >&2; exit 1 }
note() { print -r -- "${C_DIM}$*${C_OFF}" }
ok()   { print -r -- "${C_GREEN}✓${C_OFF} $*" }

# ---------- store helpers ----------
typeset -g HEADER="# psst hints v1 — id	on	kind	targets	cooldown	chance	until	tags	hint (tab-separated; '-' = empty tags)"

_ensure_store() {
  [[ -d $PSST_DIR ]] || mkdir -p "$PSST_DIR"
  [[ -f $PSST_HINTS ]] || print -r -- "$HEADER" > "$PSST_HINTS"
}

# read data rows (non-comment, non-empty) into $rows
_read_rows() {
  rows=()
  [[ -r $PSST_HINTS ]] || return 0
  local line
  while IFS= read -r line; do
    [[ -z $line || $line == \#* ]] && continue
    rows+=("$line")
  done < "$PSST_HINTS"
}

# atomically rewrite the store from $rows
_save_rows() {
  _ensure_store
  local tmp="$PSST_HINTS.tmp.$$"
  { print -r -- "$HEADER"
    (( $#rows == 0 )) || print -rl -- "${rows[@]}"
  } > "$tmp" || die "failed writing $tmp"
  command mv -f "$tmp" "$PSST_HINTS" || die "failed replacing $PSST_HINTS"
}

# sets REPLY to a fresh id not present in $rows (REPLY, not $(...): keeps
# RANDOM advancing and avoids subshells)
_gen_id() {
  local -A used
  local r
  for r in "${rows[@]}"; do used[${r%%	*}]=1; done
  while true; do
    printf -v REPLY '%04x' $(( ((RANDOM << 4) ^ RANDOM) & 0xffff ))
    [[ -z ${used[$REPLY]} ]] && return 0
  done
}

_sanitize() { print -rn -- "${1//[[:cntrl:]]/ }" }

_dur_to_secs() {
  local d=$1
  case $d in
    (<->)  print -rn -- "$d" ;;
    (<->s) print -rn -- "${d%s}" ;;
    (<->m) print -rn -- $(( ${d%m} * 60 )) ;;
    (<->h) print -rn -- $(( ${d%h} * 3600 )) ;;
    (<->d) print -rn -- $(( ${d%d} * 86400 )) ;;
    (<->w) print -rn -- $(( ${d%w} * 604800 )) ;;
    (*) return 1 ;;
  esac
}

_secs_to_human() {
  local s=$1
  if   (( s >= 604800 )); then print -rn -- "$(( s / 604800 ))w"
  elif (( s >= 86400 ));  then print -rn -- "$(( s / 86400 ))d"
  elif (( s >= 3600 ));   then print -rn -- "$(( s / 3600 ))h"
  elif (( s >= 60 ));     then print -rn -- "$(( s / 60 ))m"
  else print -rn -- "${s}s"
  fi
}

# find row index by id in $rows; sets REPLY or dies
_row_index() {
  local id=$1 i
  for i in {1..$#rows}; do
    [[ ${rows[$i]%%	*} == "$id" ]] && { REPLY=$i; return 0 }
  done
  die "no hint with id '$id' (see: psst list)"
}

_when_desc() { # kind targets -> human description of when it fires
  local kind=$1 targets=$2
  case $kind in
    cmd) print -rn -- "${targets//,/, }" ;;
    pat) print -rn -- "match: $targets" ;;
    any) print -rn -- "any command" ;;
  esac
}

# ---------- hidden commands (per-command mute) ----------
_read_hidden() { # fills $hidden (declare in caller)
  hidden=()
  [[ -r $PSST_DIR/hidden ]] || return 0
  local line
  while IFS= read -r line || [[ -n $line ]]; do
    [[ -z $line || $line == \#* ]] && continue
    hidden+=("$line")
  done < "$PSST_DIR/hidden"
}

_save_hidden() {
  _ensure_store
  local tmp="$PSST_DIR/hidden.tmp.$$"
  { (( $#hidden == 0 )) || print -rl -- "${hidden[@]}" } > "$tmp" || die "failed writing $tmp"
  command mv -f "$tmp" "$PSST_DIR/hidden" || die "failed updating hidden list"
}

_unhide() { # <cmd>; returns 1 if it wasn't hidden
  local -a hidden; _read_hidden
  local i=${hidden[(Ie)$1]}
  (( i )) || return 1
  hidden[$i]=()
  _save_hidden
  ok "${C_BOLD}$1${C_OFF} is visible again"
  return 0
}

# _row_suppressed <tags> — 0 if an unless= tag matches a present tool
# (i.e. the hint never fires on this machine)
_row_suppressed() {
  local tag u
  [[ $1 == *unless=* ]] || return 1
  for tag in ${(s:,:)1}; do
    if [[ $tag == unless=* ]]; then
      u=${tag#unless=}
      (( $+commands[$u] || $+functions[$u] || $+aliases[$u] )) && return 0
    fi
  done
  return 1
}

# _pat_word <pattern> — sets REPLY to the pattern's base command if its first
# word is a plain name ("git push *…" → git), "" for globby ones
_pat_word() {
  local w=${1%% *}
  if [[ -n $w && $w == [a-zA-Z0-9._+:@/-]## ]]; then REPLY=${w:t}; else REPLY=""; fi
}

# _rows_for_base <base> — fills $match_idx with indices (into $rows) of hints
# scoped to that base command; base "any" selects the --any hints
_rows_for_base() {
  local base=$1 i REPLY
  match_idx=()
  (( $#rows )) || return 0
  for i in {1..$#rows}; do
    local -a F; F=("${(@ps:\t:)rows[$i]}")
    case $F[3] in
      cmd) [[ ",$F[4]," == *",$base,"* ]] && match_idx+=($i) ;;
      pat) _pat_word "$F[4]"; [[ $REPLY == "$base" ]] && match_idx+=($i) ;;
      any) [[ $base == any ]] && match_idx+=($i) ;;
    esac
  done
}

# ---------- subcommands ----------
psst_cmd_add() {
  local kind=cmd cooldown=0 chance=100 snooze=0 id=""
  local -a tags
  local targets="" dir=""
  while (( $# )); do
    case $1 in
      --pat|-P)      kind=pat; shift ;;
      --any|-A)      kind=any; shift ;;
      --warn|-w)     tags+=("confirm=warn"); shift ;;
      --danger|-D)   tags+=("confirm=danger"); shift ;;
      --no-guard)    tags+=("confirm=off"); shift ;;
      --cooldown|--chance|--tag|--unless|--in|--id|-c|-p|-t|-u)
        # value-taking flags: a dangling one must die here — a failed `shift 2`
        # would leave $1 in place and spin the loop forever
        (( $# >= 2 )) || die "$1 needs a value (see: psst help)"
        case $1 in
          --cooldown|-c) cooldown=$(_dur_to_secs "$2") || die "bad duration: $2" ;;
          --chance|-p)   chance=$2; [[ $chance == <-> ]] && (( chance >= 1 && chance <= 100 )) || die "chance must be 1-100" ;;
          --tag|-t)      tags+=("$2") ;;
          --unless|-u)   tags+=("unless=$2") ;;
          --in)          dir=${2:A} ;;
          --id)          id=$2 ;;
        esac
        shift 2 ;;
      --)            shift; break ;;
      -*)            die "unknown flag: $1 (see: psst help)" ;;
      *)             break ;;
    esac
  done
  if [[ $kind != any ]]; then
    (( $# >= 2 )) || die "usage: psst add [flags] <targets> <hint...>"
    targets=$1; shift
  else
    targets="-"
    (( $# >= 1 )) || die "usage: psst add --any [flags] <hint...>"
  fi
  local hint; hint=$(_sanitize "$*")
  [[ -n ${hint// } ]] || die "empty hint"
  [[ $kind == cmd ]] && targets=${targets// }

  [[ -n $dir ]] && tags+=("in=$dir")
  local tagstr="-"
  (( $#tags )) && tagstr=${(j:,:)tags}

  local -a rows; _read_rows
  local REPLY
  [[ -n $id ]] || { _gen_id; id=$REPLY }
  rows+=("${id}	1	${kind}	${targets}	${cooldown}	${chance}	${snooze}	${tagstr}	${hint}")
  _save_rows
  ok "added ${C_BOLD}${id}${C_OFF} — fires on ${C_CYAN}$(_when_desc $kind "$targets")${C_OFF}"
  _psst_guard_level "$tagstr" "$hint"
  PSST_FORCE=1 _psst_emit "$hint" "$REPLY"
  case $REPLY in
    warn)   note "guarded: ⚠️ ${PSST_GUARD_WARN:-30}s Are-you-sure countdown before the command runs" ;;
    danger) note "guarded: ❗ ${PSST_GUARD_DANGER:-60}s red countdown before the command runs" ;;
  esac
}

psst_cmd_list() {
  local porcelain=0 tui_lines=0 full=0 filter=""
  while (( $# )); do
    case $1 in
      --porcelain) porcelain=1; shift ;;
      --tui-lines) tui_lines=1; shift ;;
      --full|-f)   full=1; shift ;;
      *) filter=$1; full=1; shift ;;
    esac
  done
  local -a rows; _read_rows
  if (( ! $#rows )); then
    (( porcelain || tui_lines )) && return 0
    note "no hints yet — try: psst add nano \"Use fresh for a more modern file editor! :D\""
    return 0
  fi
  if (( ! full && ! porcelain && ! tui_lines )); then
    _list_table
    return 0
  fi
  local now=$EPOCHSECONDS shown=0 enabled=0
  local row id on kind targets cooldown chance snooze tags hint
  local -a out
  for row in "${rows[@]}"; do
    local -a F; F=("${(@ps:\t:)row}")
    id=$F[1] on=$F[2] kind=$F[3] targets=$F[4] cooldown=$F[5] chance=$F[6] snooze=$F[7] tags=$F[8] hint=$F[9]
    [[ $on == 1 ]] && (( enabled++ ))
    if [[ -n $filter ]]; then
      [[ $targets == *$filter* || $hint == *$filter* || $tags == *$filter* || $id == $filter ]] || continue
    fi
    (( shown++ ))
    if (( porcelain )); then
      print -r -- "$row"
      continue
    fi
    local mark="${C_GREEN}●${C_OFF}"
    [[ $on != 1 ]] && mark="${C_DIM}○${C_OFF}"
    (( snooze > now )) && mark="${C_YEL}◐${C_OFF}"
    local extras="" REPLY=""
    (( cooldown > 0 )) && extras+=" ${C_DIM}⏱$(_secs_to_human $cooldown)${C_OFF}"
    (( chance < 100 )) && extras+=" ${C_DIM}🎲${chance}%${C_OFF}"
    (( snooze > now )) && extras+=" ${C_YEL}zzz $(_secs_to_human $(( snooze - now )))${C_OFF}"
    _psst_guard_level "$tags" "$hint"
    [[ $REPLY == warn ]]   && extras+=" ${C_YEL}⚠️ guarded${C_OFF}"
    [[ $REPLY == danger ]] && extras+=" ${C_RED}❗ guarded${C_OFF}"
    [[ $tags != - ]] && extras+=" ${C_DIM}[$tags]${C_OFF}"
    local line="${C_DIM}${id}${C_OFF}  ${mark}  ${C_CYAN}$(_when_desc $kind "$targets")${C_OFF}  ${hint}${extras}"
    if (( tui_lines )); then
      print -r -- "${id}	${line}"
    else
      out+=("$line")
    fi
  done
  (( porcelain || tui_lines )) && return 0
  print -r -- "${C_PINK}${C_BOLD}psst${C_OFF} ${C_DIM}· $shown shown / $#rows hints ($enabled on)${C_OFF}"
  print -rl -- "${out[@]}"
}

# the default `psst list` view: one row per base command, count + example hint
_list_table() { # expects $rows
  local -A bcount bon bex bsupp
  local -a border
  local row b t supp REPLY
  for row in "${rows[@]}"; do
    local -a F; F=("${(@ps:\t:)row}")
    local -a bs; bs=()
    case $F[3] in
      cmd) for t in ${(s:,:)F[4]}; do [[ -n $t ]] && bs+=("$t"); done ;;
      pat) _pat_word "$F[4]"; bs=("${REPLY:-(patterns)}") ;;
      any) bs=("(any)") ;;
    esac
    supp=0
    _row_suppressed "$F[8]" && supp=1
    for b in "${bs[@]}"; do
      [[ -z ${bcount[$b]} ]] && border+=("$b")
      (( bcount[$b]++ ))
      (( bsupp[$b] += supp ))
      [[ $F[2] == 1 ]] && (( bon[$b]++ ))
      [[ -z ${bex[$b]} ]] && bex[$b]=$F[9]
    done
  done
  local -a named special
  for b in "${(o)border[@]}"; do
    if [[ $b == \(* ]]; then special+=("$b"); else named+=("$b"); fi
  done
  border=("${named[@]}" "${special[@]}")
  local -a hidden; _read_hidden

  local cw=7
  for b in "${border[@]}" "${hidden[@]}"; do (( ${#b} > cw )) && cw=${#b}; done
  (( cw > 20 )) && cw=20
  local exw=$(( ${COLUMNS:-100} - cw - 16 ))
  (( exw < 24 )) && exw=24

  print -r -- "${C_PINK}${C_BOLD}psst${C_OFF} ${C_DIM}· $#rows hints across $#border commands · details: psst <command> list${C_OFF}"
  local pad
  printf -v pad '%-*s' $cw "COMMAND"
  print -r -- "${C_DIM}    ${pad}  HINTS  EXAMPLE${C_OFF}"
  local mark cnt ex hnote
  for b in "${border[@]}"; do
    mark="${C_GREEN}●${C_OFF}"
    (( ${bon[$b]:-0} == 0 )) && mark="${C_DIM}○${C_OFF}"
    hnote=""
    if (( ${bsupp[$b]:-0} >= bcount[$b] )); then
      mark="${C_DIM}◇${C_OFF}"
      hnote=" ${C_DIM}(already using it)${C_OFF}"
    fi
    if (( ${hidden[(Ie)$b]} )); then
      mark="${C_YEL}○${C_OFF}"
      hnote=" ${C_YEL}(hidden)${C_OFF}"
    fi
    cnt=${bcount[$b]}
    (( ${bon[$b]:-0} < bcount[$b] )) && cnt="${bon[$b]:-0}/${bcount[$b]}"
    ex=${bex[$b]}
    (( ${#ex} > exw )) && ex="${ex[1,$(( exw - 1 ))]}…"
    printf -v pad '%-*s' $cw "${b[1,$cw]}"
    print -r -- "  $mark ${C_CYAN}${pad}${C_OFF}  ${(l:5:)cnt}  ${ex}${hnote}"
  done
  for b in "${hidden[@]}"; do
    [[ -n ${bcount[$b]} ]] && continue
    printf -v pad '%-*s' $cw "${b[1,$cw]}"
    print -r -- "  ${C_YEL}○${C_OFF} ${C_CYAN}${pad}${C_OFF}  ${(l:5:)0}  ${C_DIM}—${C_OFF} ${C_YEL}(hidden)${C_OFF}"
  done
  print -r -- "${C_DIM}psst <command> list|add|rm · psst hide/show <command> · everything: psst list --full${C_OFF}"
}

psst_cmd_hide() {
  local -a hidden; _read_hidden
  if (( ! $# )); then
    if (( $#hidden )); then
      print -r -- "${C_PINK}${C_BOLD}psst hidden commands${C_OFF} ${C_DIM}(unhide with: psst show <command>)${C_OFF}"
      local c
      for c in "${hidden[@]}"; do print -r -- "  ${C_YEL}○${C_OFF} $c"; done
    else
      note "nothing hidden — mute all hints for a command with: psst hide <command>"
    fi
    return 0
  fi
  local c
  for c in "$@"; do
    c=${c:t}
    if (( ${hidden[(Ie)$c]} )); then
      note "$c is already hidden"
    else
      hidden+=("$c")
      _save_hidden
      ok "psst is now hidden for ${C_BOLD}$c${C_OFF} — hints kept, nothing fires (unhide: psst show $c)"
    fi
  done
}

psst_cmd_unhide() {
  (( $# )) || die "usage: psst unhide <command>"
  local c
  for c in "$@"; do
    _unhide "$c" || note "$c wasn't hidden"
  done
}

psst_cmd_show() {
  [[ -n $1 ]] || die "usage: psst show <id|hidden-command>"
  local -a rows; _read_rows
  # a hint id? show its details (ids win over command names)
  local i
  if (( $#rows )); then
    for i in {1..$#rows}; do
      [[ ${rows[$i]%%	*} == "$1" ]] && { _show_row $i; return 0 }
    done
  fi
  # a hidden command? unhide it
  _unhide "$1" && return 0
  die "'$1' is neither a hint id nor a hidden command (see: psst list · psst hide)"
}

_show_row() { # <index into $rows>
  local -a F; F=("${(@ps:\t:)rows[$1]}")
  local now=$EPOCHSECONDS
  print -r -- "${C_BOLD}id${C_OFF}        $F[1]"
  print -r -- "${C_BOLD}enabled${C_OFF}   $([[ $F[2] == 1 ]] && print -n yes || print -n no)"
  print -r -- "${C_BOLD}fires on${C_OFF}  $(_when_desc $F[3] "$F[4]")"
  print -r -- "${C_BOLD}cooldown${C_OFF}  $([[ $F[5] == 0 ]] && print -n "none" || _secs_to_human $F[5])"
  print -r -- "${C_BOLD}chance${C_OFF}    $F[6]%"
  if (( F[7] > now )); then
    print -r -- "${C_BOLD}snoozed${C_OFF}   for another $(_secs_to_human $(( F[7] - now )))"
  else
    print -r -- "${C_BOLD}snoozed${C_OFF}   no"
  fi
  print -r -- "${C_BOLD}tags${C_OFF}      $F[8]"
  local REPLY; _psst_guard_level "$F[8]" "$F[9]"
  case $REPLY in
    warn)   print -r -- "${C_BOLD}guard${C_OFF}     ${C_YEL}⚠️ warn — ${PSST_GUARD_WARN:-30}s Are-you-sure countdown${C_OFF}" ;;
    danger) print -r -- "${C_BOLD}guard${C_OFF}     ${C_RED}❗ danger — ${PSST_GUARD_DANGER:-60}s countdown, red alert${C_OFF}" ;;
    *)      print -r -- "${C_BOLD}guard${C_OFF}     none" ;;
  esac
  print -r -- "${C_BOLD}hint${C_OFF}      $F[9]"
  print
  PSST_FORCE=1 _psst_emit "$F[9]" "$REPLY"
}

psst_cmd_rm() {
  (( $# )) || die "usage: psst rm <id...> | --tag <tag> | --all"
  local -a rows; _read_rows
  local before=$#rows
  case $1 in
    --all)
      rows=()
      ;;
    --tag)
      [[ -n $2 ]] || die "usage: psst rm --tag <tag>"
      local -a keep; local r
      for r in "${rows[@]}"; do
        local -a F; F=("${(@ps:\t:)r}")
        [[ ",$F[8]," == *",$2,"* ]] || keep+=("$r")
      done
      rows=("${keep[@]}")
      ;;
    *)
      local id REPLY
      for id in "$@"; do
        _row_index "$id"
        rows[$REPLY]=()
      done
      ;;
  esac
  _save_rows
  ok "removed $(( before - $#rows )) hint(s)"
}

_set_field() { # id field_index value
  local -a rows; _read_rows
  local REPLY; _row_index "$1"; local i=$REPLY
  local -a F; F=("${(@ps:\t:)rows[$i]}")
  F[$2]=$3
  rows[$i]=${(pj:\t:)F}
  _save_rows
}

psst_cmd_toggle() {
  [[ -n $1 ]] || die "usage: psst toggle <id...>"
  local id REPLY
  for id in "$@"; do
    local -a rows; _read_rows
    _row_index "$id"
    local -a F; F=("${(@ps:\t:)rows[$REPLY]}")
    local new=1; [[ $F[2] == 1 ]] && new=0
    _set_field "$id" 2 $new
    ok "$id is now $([[ $new == 1 ]] && print -n on || print -n off)"
  done
}

psst_cmd_on() {
  if (( ! $# )); then
    command rm -f "$PSST_DIR/off"
    ok "psst is on"
    return
  fi
  local id
  for id in "$@"; do _set_field "$id" 2 1; ok "$id on"; done
}

psst_cmd_off() {
  if (( ! $# )); then
    _ensure_store
    : > "$PSST_DIR/off"
    ok "psst is off (re-enable with: psst on)"
    return
  fi
  local id
  for id in "$@"; do _set_field "$id" 2 0; ok "$id off"; done
}

psst_cmd_snooze() {
  [[ -n $1 ]] || die "usage: psst snooze <id> [duration, default 1d]"
  local secs; secs=$(_dur_to_secs "${2:-1d}") || die "bad duration: $2 (try 30m, 2h, 7d)"
  _set_field "$1" 7 $(( EPOCHSECONDS + secs ))
  ok "$1 snoozed for $(_secs_to_human $secs)"
}

psst_cmd_wake() {
  [[ -n $1 ]] || die "usage: psst wake <id>"
  _set_field "$1" 7 0
  ok "$1 is awake"
}

psst_cmd_done() {
  [[ -n $1 ]] || die "usage: psst done <id>   (marks a hint as learned → disabled)"
  local -a rows; _read_rows
  local REPLY; _row_index "$1"; local i=$REPLY
  local -a F; F=("${(@ps:\t:)rows[$i]}")
  F[2]=0
  [[ ",$F[8]," == *,learned,* ]] || F[8]=$([[ $F[8] == - ]] && print -n learned || print -n "$F[8],learned")
  rows[$i]=${(pj:\t:)F}
  _save_rows
  ok "nice — '$F[9]' marked as learned 🎓 (kept, disabled; revive with: psst on $F[1])"
}

psst_cmd_edit() {
  _ensure_store
  ${=${VISUAL:-${EDITOR:-vi}}} "$PSST_HINTS"
}

psst_cmd_find() { psst_cmd_list --full "$@" }

# ---------- command-scoped verbs: psst <basecommand> [list|add|rm|hide|show] ----------
_scope_list() { # <base>
  local base=$1
  local -a rows match_idx
  _read_rows
  _rows_for_base "$base"
  local -a hidden; _read_hidden
  local hid=""
  (( ${hidden[(Ie)$base]} )) && hid=" ${C_YEL}· hidden (unhide: psst show $base)${C_OFF}"
  if (( ! $#match_idx )); then
    note "no hints for '$base' yet — add one: psst $base add \"your hint here\"$hid"
    note "(if you meant a psst command, see: psst help)"
    return 0
  fi
  print -r -- "${C_PINK}${C_BOLD}psst · $base${C_OFF} ${C_DIM}— $#match_idx hint$( (( $#match_idx > 1 )) && print -n s )${C_OFF}$hid"
  local n=0 i now=$EPOCHSECONDS
  for i in "${match_idx[@]}"; do
    (( n++ ))
    local -a F; F=("${(@ps:\t:)rows[$i]}")
    local mark="${C_GREEN}●${C_OFF}"
    [[ $F[2] != 1 ]] && mark="${C_DIM}○${C_OFF}"
    (( F[7] > now )) && mark="${C_YEL}◐${C_OFF}"
    local when=""
    [[ $F[3] == pat ]] && when=" ${C_DIM}(match: $F[4])${C_OFF}"
    if [[ $F[3] == cmd && $F[4] != "$base" ]]; then
      local -a others; others=(${(s:,:)F[4]})
      others=("${(@)others:#$base}")
      (( $#others )) && when=" ${C_DIM}(also: ${(j:, :)others})${C_OFF}"
    fi
    local extras="" REPLY=""
    _row_suppressed "$F[8]" && extras+=" ${C_DIM}◇ already using it${C_OFF}"
    _psst_guard_level "$F[8]" "$F[9]"
    [[ $REPLY == warn ]]   && extras+=" ${C_YEL}⚠️ guarded${C_OFF}"
    [[ $REPLY == danger ]] && extras+=" ${C_RED}❗ guarded${C_OFF}"
    (( F[5] > 0 )) && extras+=" ${C_DIM}⏱$(_secs_to_human $F[5])${C_OFF}"
    (( F[6] < 100 )) && extras+=" ${C_DIM}🎲${F[6]}%${C_OFF}"
    (( F[7] > now )) && extras+=" ${C_YEL}zzz $(_secs_to_human $(( F[7] - now )))${C_OFF}"
    [[ $F[8] != - ]] && extras+=" ${C_DIM}[$F[8]]${C_OFF}"
    print -r -- "  ${C_BOLD}${(l:2:)n}${C_OFF}  $mark  $F[9]$when ${C_DIM}($F[1])${C_OFF}$extras"
  done
  print -r -- "${C_DIM}psst $base add \"…\" · psst $base rm <n> · psst hide $base${C_OFF}"
}

psst_scope() { # <base> [verb] [args...]
  local base=${1:t}; shift
  local verb=${1:-list}
  (( $# )) && shift
  case $verb in
    list|ls)
      _scope_list "$base"
      ;;
    add)
      local -a flags
      while (( $# )); do
        case $1 in
          --cooldown|-c|--chance|-p|--tag|-t|--unless|-u|--in|--id)
            (( $# >= 2 )) || die "$1 needs a value (see: psst help)"
            flags+=("$1" "$2"); shift 2 ;;
          --pat|-P|--any|-A)
            die "psst $base add takes plain hints — use 'psst add $1 …' for pattern/any hints" ;;
          *) break ;;
        esac
      done
      (( $# )) || die "usage: psst $base add [flags] <hint...>"
      if [[ $base == any ]]; then
        psst_cmd_add --any "${flags[@]}" "$@"
      else
        psst_cmd_add "${flags[@]}" "$base" "$@"
      fi
      ;;
    rm|remove)
      (( $# )) || die "usage: psst $base rm <n|id>   (numbers from: psst $base list)"
      local -a rows match_idx
      _read_rows
      _rows_for_base "$base"
      local -a ids
      local sel
      for sel in "$@"; do
        # ordinals from `psst <cmd> list` win; anything else (incl. an
        # out-of-range number that might be an all-digit id) is tried as an id
        if [[ $sel == <-> ]] && (( sel >= 1 && sel <= $#match_idx )); then
          ids+=("${rows[$match_idx[$sel]]%%	*}")
        else
          ids+=("$sel")
        fi
      done
      psst_cmd_rm "${ids[@]}"
      ;;
    hide)   psst_cmd_hide "$base" ;;
    show|unhide) _unhide "$base" || note "$base wasn't hidden" ;;
    on|off)
      local -a rows match_idx
      _read_rows
      _rows_for_base "$base"
      (( $#match_idx )) || die "no hints for '$base'"
      local -a ids
      local i
      for i in "${match_idx[@]}"; do ids+=("${rows[$i]%%	*}"); done
      psst_cmd_$verb "${ids[@]}"
      ;;
    *)
      die "unknown: psst $base $verb — try: psst $base [list|add <hint...>|rm <n>|hide|show|on|off]"
      ;;
  esac
}

psst_cmd_try() {
  (( $# )) || die "usage: psst try <command line...>"
  local line="$*"
  _psst_load
  local REPLY base
  _psst_effective_word "$line" ""
  base=$REPLY
  local -a hidden; _read_hidden
  if [[ -n $base ]] && (( ${hidden[(Ie)$base]} )); then
    print -r -- "${C_YEL}psst is hidden for '$base' — nothing will fire${C_OFF} ${C_DIM}(unhide: psst show $base)${C_OFF}"
  fi
  local -a reply
  _psst_match "$line" ""
  if (( ! $#reply )); then
    note "no hints match: $line"
    return 0
  fi
  local now=$EPOCHSECONDS rec
  print -r -- "${C_PINK}${C_BOLD}psst${C_OFF} ${C_DIM}· $#reply hint(s) match:${C_OFF} $line"
  for rec in "${reply[@]}"; do
    local -a f; f=("${(@ps:\x1f:)rec}")   # id cooldown chance until dir guard hint
    local why=""
    (( f[4] > now )) && why+=" ${C_YEL}(snoozed)${C_OFF}"
    if [[ $f[5] != - ]]; then
      [[ $PWD == ${~f[5]}* ]] || why+=" ${C_YEL}(only in $f[5])${C_OFF}"
    fi
    (( f[3] < 100 )) && why+=" ${C_DIM}(${f[3]}% chance)${C_OFF}"
    case $f[6] in
      warn)   why+=" ${C_YEL}(guard: ⚠️ ${PSST_GUARD_WARN:-30}s countdown)${C_OFF}" ;;
      danger) why+=" ${C_RED}(guard: ❗ ${PSST_GUARD_DANGER:-60}s countdown)${C_OFF}" ;;
    esac
    print -r -- "  ${C_DIM}$f[1]${C_OFF}  $f[7]$why"
  done
}

psst_cmd_pack() {
  local sub=${1:-list}; shift 2>/dev/null
  local packdir="$PSST_ROOT/packs"
  case $sub in
    list)
      print -r -- "${C_PINK}${C_BOLD}psst packs${C_OFF} ${C_DIM}(install with: psst pack install <name>)${C_OFF}"
      local -a rows; _read_rows
      local p name count installed n
      for p in "$packdir"/*.tsv(N); do
        name=${p:t:r}
        count=$(grep -Evc '^#|^$' "$p")
        installed=""
        n=${#${(M)rows:#*pack:${name}*}}
        (( n )) && installed=" ${C_GREEN}✓ installed ($n hints)${C_OFF}"
        print -r -- "  ${C_CYAN}${name}${C_OFF} ${C_DIM}($count hints)${C_OFF}$installed"
      done
      ;;
    install)
      (( $# )) || die "usage: psst pack install <name|path> ..."
      local src file
      for src in "$@"; do
        if [[ -f $src ]]; then file=$src
        elif [[ -f $packdir/$src.tsv ]]; then file=$packdir/$src.tsv
        else die "no pack '$src' (see: psst pack list)"
        fi
        local name=${file:t:r} added=0 skipped=0
        local -a rows; _read_rows
        # pack rows: kind  targets  cooldown  chance  tags  hint
        local kind targets cooldown chance ptags hint r dupe tagstr REPLY
        while IFS=$'\t' read -r kind targets cooldown chance ptags hint || [[ -n $kind ]]; do
          [[ -z $kind || $kind == \#* ]] && continue
          dupe=0
          for r in "${rows[@]}"; do
            local -a F; F=("${(@ps:\t:)r}")
            [[ $F[3] == $kind && $F[4] == $targets && $F[9] == $hint ]] && { dupe=1; break }
          done
          (( dupe )) && { (( skipped++ )); continue }
          tagstr="pack:${name}"
          [[ -n $ptags && $ptags != - ]] && tagstr+=",$ptags"
          _gen_id
          rows+=("$REPLY	1	${kind}	${targets}	${cooldown:-0}	${chance:-100}	0	${tagstr}	${hint}")
          (( added++ ))
        done < "$file"
        _save_rows
        ok "pack ${C_CYAN}${name}${C_OFF}: $added added$( (( skipped )) && print -n ", $skipped already present" )"
      done
      ;;
    remove|rm)
      (( $# )) || die "usage: psst pack remove <name>"
      psst_cmd_rm --tag "pack:$1"
      ;;
    *) die "usage: psst pack [list|install <name>|remove <name>]" ;;
  esac
}

psst_cmd_export() {
  [[ -r $PSST_HINTS ]] || die "nothing to export"
  if [[ -n $1 ]]; then
    command cp "$PSST_HINTS" "$1" && ok "exported to $1"
  else
    command cat "$PSST_HINTS"
  fi
}

psst_cmd_import() {
  [[ -r $1 ]] || die "usage: psst import <file.tsv>"
  local -a rows; _read_rows
  local line added=0 bad=0 REPLY
  local -A used
  local r
  for r in "${rows[@]}"; do used[${r%%	*}]=1; done
  while IFS= read -r line || [[ -n $line ]]; do
    [[ -z $line || $line == \#* ]] && continue
    local -a F; F=("${(@ps:\t:)line}")
    if (( $#F < 9 )); then (( bad++ )); continue; fi
    (( $#F > 9 )) && F=("${(@)F[1,8]}" "${(pj:\t:)F[9,-1]}")
    if [[ -n ${used[$F[1]]} ]]; then
      _gen_id
      F[1]=$REPLY
    fi
    used[$F[1]]=1
    rows+=("${(pj:\t:)F}")
    (( added++ ))
  done < "$1"
  _save_rows
  ok "imported $added hint(s)$( (( bad )) && print -n " ${C_YEL}($bad malformed rows skipped)${C_OFF}" )"
}

psst_cmd_stats() {
  local log="$PSST_STATE_DIR/shown.log"
  if [[ $1 == --reset ]]; then
    command rm -f "$log"
    ok "stats reset"
    return
  fi
  [[ -s $log ]] || { note "no hints shown yet"; return 0 }
  local -A counts lastts hints
  local ts id
  while IFS=$'\t' read -r ts id; do
    (( counts[$id]++ ))
    lastts[$id]=$ts
  done < "$log"
  local -a rows; _read_rows
  local r
  for r in "${rows[@]}"; do
    local -a F; F=("${(@ps:\t:)r}")
    hints[$F[1]]=$F[9]
  done
  print -r -- "${C_PINK}${C_BOLD}psst stats${C_OFF} ${C_DIM}· times each hint fired${C_OFF}"
  local -a lines
  for id in ${(k)counts}; do
    lines+=("${(l:6:)counts[$id]}  ${C_DIM}${id}${C_OFF}  ${hints[$id]:-${C_DIM}(deleted)${C_OFF}}")
  done
  print -rl -- "${(On)lines[@]}"
}

psst_cmd_guard() {
  local f="$PSST_DIR/guard-off"
  case ${1:-status} in
    status)
      if [[ -e $f ]]; then
        print -r -- "${C_PINK}${C_BOLD}psst guard${C_OFF} is ${C_RED}off${C_OFF} ${C_DIM}— warning hints show but never pause for confirmation${C_OFF}"
      else
        print -r -- "${C_PINK}${C_BOLD}psst guard${C_OFF} is ${C_GREEN}on${C_OFF} — ${C_YEL}⚠️ warn${C_OFF} hints hold ${PSST_GUARD_WARN:-30}s, ${C_RED}❗ danger${C_OFF} hints hold ${PSST_GUARD_DANGER:-60}s"
        print -r -- "${C_DIM}Enter = run now · Esc/Ctrl+C = cancel · timeout = auto-run${C_OFF}"
        print -r -- "${C_DIM}durations: PSST_GUARD_WARN / PSST_GUARD_DANGER in $PSST_DIR/config.zsh${C_OFF}"
      fi
      ;;
    on)  command rm -f "$f"; ok "guard on — ⚠️/❗ hints now ask before the command runs" ;;
    off) _ensure_store; : > "$f"; ok "guard off — warnings still show, commands run immediately" ;;
    *)   die "usage: psst guard [status|on|off]" ;;
  esac
}

# resolve the effective pause seconds the way the hook does (file > default;
# the CLI ignores session-local $PSST_PAUSE on purpose — this is the global view)
_pause_current() {
  if [[ -r $PSST_DIR/pause ]]; then REPLY=$(<$PSST_DIR/pause); else REPLY=1; fi
  [[ $REPLY == (<->|<->.<->|.<->) ]] || REPLY=1
}

psst_cmd_pause() {
  local f="$PSST_DIR/pause" REPLY
  case ${1:-status} in
    status)
      _pause_current
      if (( REPLY > 0 )); then
        print -r -- "${C_PINK}${C_BOLD}psst pause${C_OFF} is ${C_GREEN}on${C_OFF} — ${REPLY}s before the first hint-ed run of each command, resets daily"
      else
        print -r -- "${C_PINK}${C_BOLD}psst pause${C_OFF} is ${C_RED}off${C_OFF}"
      fi
      # show + prune today's paused set
      local pfile="$PSST_STATE_DIR/paused.tsv" today
      strftime -s today '%Y-%m-%d' $EPOCHSECONDS
      if [[ -r $pfile ]]; then
        local -a keep todays
        local d c
        while IFS=$'\t' read -r d c || [[ -n $d ]]; do
          [[ $d == "$today" ]] && { keep+=("$d	$c"); todays+=("$c") }
        done < "$pfile"
        local tmp="$pfile.tmp.$$"
        { (( $#keep == 0 )) || print -rl -- "${keep[@]}" } > "$tmp" && command mv -f "$tmp" "$pfile"
        (( $#todays )) && print -r -- "${C_DIM}already paused today: ${(j:, :)todays}${C_OFF}"
      fi
      ;;
    on)
      command rm -f "$f"
      ok "pause on — 1s before the first hint-ed run of each command, resets daily"
      ;;
    off)
      _ensure_store
      print -r -- 0 > "$f"
      ok "pause off — hints still show, commands start instantly"
      ;;
    (<->|<->.<->|.<->))
      _ensure_store
      print -r -- "$1" > "$f"
      ok "pause set to ${1}s (per command, once a day)"
      ;;
    *)
      die "usage: psst pause [status|on|off|<seconds>]"
      ;;
  esac
}

psst_cmd_demo() {
  print -r -- "${C_DIM}this is how hints look (customize in $PSST_DIR/config.zsh):${C_OFF}"
  PSST_FORCE=1 _psst_emit "Use fresh for a more modern file editor! :D"
  PSST_FORCE=1 PSST_ICON="🌱" PSST_PREFIX="tip" _psst_emit "icons and prefix are configurable"
  PSST_FORCE=1 _psst_emit "⚠️ warning hints hold the command — Are you sure? (${PSST_GUARD_WARN:-30}s countdown)" warn
  PSST_FORCE=1 _psst_emit "❗ dangerous ones go red and hold ${PSST_GUARD_DANGER:-60}s — Esc cancels the command" danger
}

psst_cmd_status() {
  local state="${C_GREEN}on${C_OFF}"
  [[ -e $PSST_DIR/off ]] && state="${C_RED}off${C_OFF}"
  local -a rows; _read_rows
  local enabled=0 r
  for r in "${rows[@]}"; do
    local -a F; F=("${(@ps:\t:)r}")
    [[ $F[2] == 1 ]] && (( enabled++ ))
  done
  local REPLY; _pause_current
  local pstate="pause ${REPLY}s"
  (( REPLY > 0 )) || pstate="pause off"
  local gstate="guard on"
  [[ -e $PSST_DIR/guard-off ]] && gstate="guard off"
  print -r -- "${C_PINK}${C_BOLD}psst${C_OFF} v$PSST_VERSION is $state ${C_DIM}· $enabled/$#rows hints enabled · $pstate · $gstate${C_OFF}"
  local -a hidden; _read_hidden
  (( $#hidden )) && print -r -- "${C_DIM}hidden: ${(j:, :)hidden}${C_OFF}"
  print -r -- "${C_DIM}hints:  $PSST_HINTS${C_OFF}"
  print -r -- "${C_DIM}plugin: $PSST_ROOT${C_OFF}"
}

psst_cmd_doctor() {
  local fails=0
  _check() { # label ok-bool detail
    if (( $2 )); then print -r -- "${C_GREEN}✓${C_OFF} $1"
    else print -r -- "${C_RED}✗${C_OFF} $1 ${C_DIM}— $3${C_OFF}"; (( fails++ ))
    fi
  }
  autoload -Uz is-at-least
  is-at-least 5.3 $ZSH_VERSION; _check "zsh $ZSH_VERSION (>= 5.3)" $(( ! $? )) "upgrade zsh"
  [[ -r $PSST_HINTS ]]; _check "hints file readable" $(( ! $? )) "run any 'psst add' to create it"
  local -a rows; _read_rows
  local badrows=0 r
  for r in "${rows[@]}"; do
    local -a F; F=("${(@ps:\t:)r}")
    (( $#F != 9 )) && (( badrows++ ))
  done
  _check "all $#rows rows well-formed (9 tab-separated columns)" $(( badrows == 0 )) "$badrows bad rows — fix with: psst edit"
  local hooked=0
  grep -qsE 'psst\.plugin\.zsh|(zinit|antidote|zplug).*psst' ~/.zshrc && hooked=1
  _check "wired into ~/.zshrc" $hooked "add: source $PSST_ROOT/psst.plugin.zsh"
  [[ ! -e $PSST_DIR/off ]]; _check "globally enabled" $(( ! $? )) "run: psst on"
  (( $+commands[fzf] )); _check "fzf available (for: psst tui)" $(( ! $? )) "brew install fzf (optional)"
  local log="$PSST_STATE_DIR/shown.log"
  if [[ -f $log ]]; then
    local -a st; zstat -A st +size -- "$log" 2>/dev/null
    _check "stats log size ${st[1]:-0}B" $(( ${st[1]:-0} < 1048576 )) "trim with: psst stats --reset"
  fi
  (( fails )) && print -r -- "${C_YEL}$fails issue(s) found${C_OFF}" || ok "all good"
  return $fails
}

psst_cmd_tui() {
  (( $+commands[fzf] )) || die "psst tui needs fzf (brew install fzf) — meanwhile: psst list"
  local out
  out=$("$SCRIPT" list --tui-lines | fzf --ansi --delimiter=$'\t' --with-nth=2 \
    --prompt="psst ❯ " \
    --header="enter: details · ctrl-t: toggle · ctrl-x: delete · ctrl-z: snooze 1d · ctrl-w: wake · esc: quit" \
    --preview="$SCRIPT show {1}" --preview-window=down,9,wrap \
    --bind="ctrl-t:execute-silent($SCRIPT toggle {1})+reload($SCRIPT list --tui-lines)" \
    --bind="ctrl-x:execute-silent($SCRIPT rm {1})+reload($SCRIPT list --tui-lines)" \
    --bind="ctrl-z:execute-silent($SCRIPT snooze {1} 1d)+reload($SCRIPT list --tui-lines)" \
    --bind="ctrl-w:execute-silent($SCRIPT wake {1})+reload($SCRIPT list --tui-lines)")
  [[ -n $out ]] && "$SCRIPT" show "${out%%	*}"
}

psst_cmd_uninstall() {
  local purge=0
  [[ $1 == --purge ]] && purge=1
  local zshrc=~/.zshrc
  if grep -qs '# >>> psst >>>' "$zshrc"; then
    command cp "$zshrc" "$zshrc.psst-backup"
    command sed -i '' '/# >>> psst >>>/,/# <<< psst <<</d' "$zshrc" 2>/dev/null \
      || command sed -i '/# >>> psst >>>/,/# <<< psst <<</d' "$zshrc"
    ok "removed psst block from ~/.zshrc (backup: ~/.zshrc.psst-backup)"
  elif grep -qs 'psst.plugin.zsh\|fire17/psst' "$zshrc"; then
    print -r -- "${C_YEL}!${C_OFF} psst is loaded from ~/.zshrc outside a psst block — remove that line manually"
  else
    note "no psst lines found in ~/.zshrc (loaded via a plugin manager? remove it there)"
  fi
  if (( purge )); then
    command rm -rf "$PSST_DIR" "$PSST_STATE_DIR"
    ok "purged hints and stats"
  else
    note "your hints are kept at $PSST_HINTS (add --purge to remove them too)"
  fi
  note "open a new shell for this to take effect 👋"
}

psst_cmd_version() { print -r -- "psst $PSST_VERSION" }

psst_cmd_help() {
  print -r -- "${C_PINK}${C_BOLD}psst${C_OFF} — gentle hints for your shell, right before you need them.

${C_BOLD}add hints${C_OFF}
  psst add <cmds> <hint...>            hint before command(s); comma-separate: nano,pico,vi
  psst add --pat '<glob>' <hint...>    hint when the full command line matches a zsh glob
  psst add --any <hint...>             hint on any command (pair with --chance/--cooldown)
    flags: --cooldown 2h  --chance 25  --tag work  --in ~/dir
           --unless zoxide   (skip the hint if that tool is already installed/active)
           --warn / --danger (hold the command behind an Are-you-sure countdown)
           hints containing ⚠️ auto-guard as warn, ❗/🚨 as danger (--no-guard opts out)

${C_BOLD}browse${C_OFF}
  psst list             table: one row per command (count + example hint)
  psst list --full      every hint, flat · psst find <text> to filter
  psst <cmd> list       numbered hints for one command (e.g. psst nano list)
  psst tui              interactive manager (fzf)
  psst show <id>        full details of one hint
  psst try <cmdline>    which hints would fire for a command line?
  psst stats            how often each hint fired

${C_BOLD}per-command${C_OFF}
  psst hide <cmd>       mute EVERYTHING psst does for that command
  psst show <cmd>       unmute it (psst hide lists what's hidden)
  psst <cmd> add <hint...>     add a hint for that command
  psst <cmd> rm <n>            remove its n-th hint (numbers from psst <cmd> list)
  psst <cmd> on / off          enable/disable all of its hints

${C_BOLD}manage${C_OFF}
  psst rm <id...>              delete (also: --tag <tag>, --all)
  psst on / off [id]           enable/disable ALL of psst globally, or one hint
  psst pause [on|off|<secs>]   1s breather before the first hint-ed run of a
                               command (once per command, resets daily)
  psst guard [on|off]          ⚠️/❗ hints hold the command behind a live countdown
                               (30s/60s · Enter = run now · Esc/Ctrl+C = cancel)
  psst toggle <id>             flip one hint
  psst snooze <id> [7d]        mute for a while     psst wake <id>  unmute
  psst done <id>               'learned it' — keep but stop showing
  psst edit                    open hints file in \$EDITOR

${C_BOLD}packs & sharing${C_OFF}
  psst pack list / install <name> / remove <name>
  psst export [file] / import <file>

${C_BOLD}setup${C_OFF}
  psst status / doctor / demo / uninstall [--purge] / version

${C_DIM}session mute: PSST_QUIET=1 · config: $PSST_DIR/config.zsh · data: $PSST_HINTS${C_OFF}"
}

# ---------- dispatch ----------
main() {
  local cmd=${1:-help}
  (( $# )) && shift
  case $cmd in
    -h|--help) cmd=help ;;
    -v|--version) cmd=version ;;
  esac
  local fn="psst_cmd_${cmd//-/_}"
  if typeset -f -- "$fn" > /dev/null; then
    "$fn" "$@"
  elif [[ $cmd == -* ]]; then
    die "unknown flag '$cmd' — see: psst help"
  else
    # not a subcommand → treat as a base command scope: psst nano [list|add|rm|…]
    psst_scope "$cmd" "$@"
  fi
}

main "$@"
